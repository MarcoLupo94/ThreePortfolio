{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": ["prettier", "plugin:node/recommended"],
    "overrides": [],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "plugins": ["prettier", "react"],
    "rules": {
        "prettier/prettier": ["error"],
        "no-unused-vars": "warn",
        "no-console": "off",
        "func-names": "off",
        "no-process-exit": "off",
        "object-shorthand": "off",
        "class-methods-use-this": "off",
        "react/react-in-jsx-scope": "off"
    }
}
